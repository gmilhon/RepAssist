# Copy to .env and fill in. Every value has a safe default so the app runs with
# ZERO credentials (it falls back to a deterministic mock LLM if no key is set).

# --- LLM ---
# Leave ANTHROPIC_API_KEY empty to run fully offline with the rule-based mock LLM.
ANTHROPIC_API_KEY=
# Default is the most capable model. Switch to claude-sonnet-4-6 to cut cost on
# high-volume triage, or claude-haiku-4-5 for the cheapest/fastest classification.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Where the "existing" agent microservices live ---
# In this prototype they are mocked by backend/app/mock_services. Point these at
# the real Activation / Promo / Pending-Order services when you integrate.
AGENT_SERVICES_BASE_URL=http://127.0.0.1:8100

# --- Examples: route an intent to a REAL, vendor-shaped agent ---
# Leave empty to use the built-in mock. The sample agents (app.sample_agent,
# run on :8200) implement both contracts; each adapter handles the translation.
# Activation uses a Bearer token; Promo uses an X-Api-Key — different on purpose.
ACTIVATION_AGENT_URL=
ACTIVATION_AGENT_TOKEN=
PROMO_AGENT_URL=
PROMO_AGENT_TOKEN=

# --- Persistence (SQLite files, created on first run) ---
TICKETS_DB_URL=sqlite:///./repassist.db
CHECKPOINT_DB=./checkpoints.sqlite

# --- Routing ---
# Confidence below this threshold escalates straight to a human ticket.
TRIAGE_CONFIDENCE_THRESHOLD=0.45

# --- CORS (frontend dev server) ---
FRONTEND_ORIGIN=http://localhost:5173

# --- LangSmith observability (optional) ---
# Set LANGCHAIN_API_KEY to enable automatic LangGraph tracing and the CX Monitor
# dashboard tab. Leave empty to run without tracing — the dashboard shows sample
# data in that case.
#   Sign up: https://smith.langchain.com
LANGCHAIN_API_KEY=
# The project name to use in LangSmith. Created automatically on first trace.
LANGCHAIN_PROJECT=rep-assist
# Token cost rates for the cost-per-conversation KPI (USD / million tokens).
# These default to claude-sonnet-4-6 pricing; adjust if you switch models.
LANGSMITH_INPUT_COST_PER_MILLION=3.0
LANGSMITH_OUTPUT_COST_PER_MILLION=15.0

# --- Email reports (optional) ---
# When set, the "Send Report" button emails real HTML reports to subscribers.
# Without these, the button shows an in-browser preview instead.
# Gmail example: use an App Password (not your account password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
